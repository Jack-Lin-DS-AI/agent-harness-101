---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';

const base = import.meta.env.BASE_URL;

const layerData = [
  { id: 'loop', num: 1, name: 'The Agent Loop', color: '#3B82F6' },
  { id: 'tools', num: 2, name: 'Tool System', color: '#F97316' },
  { id: 'context', num: 3, name: 'Context Management', color: '#8B5CF6' },
  { id: 'persistence', num: 4, name: 'Persistence', color: '#10B981' },
  { id: 'verification', num: 5, name: 'Verification', color: '#14B8A6' },
  { id: 'constraints', num: 6, name: 'Constraints', color: '#EF4444' },
];

export function getStaticPaths() {
  return [
    { params: { id: 'loop' } },
    { params: { id: 'tools' } },
    { params: { id: 'context' } },
    { params: { id: 'persistence' } },
    { params: { id: 'verification' } },
    { params: { id: 'constraints' } },
  ];
}

const { id } = Astro.params;
const layer = layerData.find(l => l.id === id)!;

// Map layer id to example filename suffix
const exampleMap: Record<string, string> = {
  loop: 'agent_loop',
  tools: 'tool_system',
  context: 'context_manager',
  persistence: 'persistence',
  verification: 'verification',
  constraints: 'constraints',
};
const exampleFile = '0' + layer.num + '_' + exampleMap[id] + '.py';

// Load snippet
let snippet = '# Snippet not found';
try {
  snippet = readFileSync(resolve(process.cwd(), 'src/snippets/0' + layer.num + '_' + id + '.py'), 'utf-8');
} catch {}

// Load content
let contentEn = '';
let contentZh = '';
try {
  contentEn = readFileSync(resolve(process.cwd(), 'src/content/en/0' + layer.num + '-' + id + '.md'), 'utf-8');
} catch {}
try {
  contentZh = readFileSync(resolve(process.cwd(), 'src/content/zh-TW/0' + layer.num + '-' + id + '.md'), 'utf-8');
} catch {}

// Simple markdown to HTML
function inlineMd(text: string): string {
  return text
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/`(.+?)`/g, '<code>$1</code>');
}

function mdToHtml(md: string): string {
  const lines = md.split('\n');
  const out: string[] = [];
  for (const line of lines) {
    if (line.startsWith('### ')) {
      out.push('<h4>' + inlineMd(line.slice(4)) + '</h4>');
    } else if (line.startsWith('## ')) {
      out.push('<h3>' + inlineMd(line.slice(3)) + '</h3>');
    } else if (line.startsWith('# ')) {
      out.push('<h2>' + inlineMd(line.slice(2)) + '</h2>');
    } else if (line.startsWith('> ')) {
      out.push('<blockquote><p>' + inlineMd(line.slice(2)) + '</p></blockquote>');
    } else if (line.startsWith('- ')) {
      out.push('<li>' + inlineMd(line.slice(2)) + '</li>');
    } else if (line.trim() !== '') {
      out.push('<p>' + inlineMd(line) + '</p>');
    }
  }
  return out.join('\n');
}

const htmlEn = contentEn ? mdToHtml(contentEn) : '<p>Content coming soon.</p>';
const htmlZh = contentZh ? mdToHtml(contentZh) : '<p>Content coming soon.</p>';

const prevMap: Record<string, string> = { tools: 'loop', context: 'tools', persistence: 'context', verification: 'persistence', constraints: 'verification' };
const nextMap: Record<string, string> = { loop: 'tools', tools: 'context', context: 'persistence', persistence: 'verification', verification: 'constraints' };
const prev = prevMap[id] || '';
const next = nextMap[id] || '';

const tsConceptCode = [
  '// Claude Code TypeScript equivalent (conceptual)',
  '// The original Claude Code implements this pattern in TypeScript.',
  '// claw-code reimplements it in Python -- see the Python tab.',
  '//',
  '// Key mapping:',
  '//   PortRuntime            -> Runtime (main orchestrator)',
  '//   QueryEnginePort        -> QueryEngine (turn processing)',
  '//   ToolPermissionContext   -> PermissionEngine (6-layer evaluation)',
  '//   StoredSession          -> SessionStore (JSON persistence)',
  '//   CostTracker            -> UsageTracker (token counting)',
].join('\n');
---
<BaseLayout title={`Layer ${layer.num}: ${layer.name}`}>
  <div class="container" style="padding-top: 2rem; padding-bottom: 4rem;">

    <div style={`border-left: 4px solid ${layer.color}; padding-left: 1.5rem; margin-bottom: 2rem;`}>
      <h1 style={`color: ${layer.color}; margin-top: 0;`}>
        Layer {layer.num}: {layer.name}
      </h1>
    </div>

    <nav style="display: flex; gap: 1rem; margin-bottom: 2rem;">
      {prev && <a href={`${base}layer/${prev}`}>&larr; Previous</a>}
      <a href={base}>All Layers</a>
      {next && <a href={`${base}layer/${next}`}>Next &rarr;</a>}
    </nav>

    <div class="split-pane">
      <div>
        <div data-lang="en">
          <Fragment set:html={htmlEn} />
        </div>
        <div data-lang="zh-TW">
          <Fragment set:html={htmlZh} />
        </div>
        <div class="callout tip" style="margin-top: 2rem;">
          <strong>Try it yourself:</strong>
          <pre><code>python examples/{exampleFile}</code></pre>
        </div>
      </div>

      <div>
        <div class="code-block">
          <div class="code-tabs">
            <button class="code-tab active" onclick="showTab(this, 'python')">Python (claw-code)</button>
            <button class="code-tab" onclick="showTab(this, 'concept')">TypeScript (concept)</button>
          </div>
          <div id="tab-python">
            <pre><code>{snippet}</code></pre>
          </div>
          <div id="tab-concept" style="display: none;">
            <pre><code>{tsConceptCode}</code></pre>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script is:inline>
function showTab(btn, tabId) {
  btn.parentElement.querySelectorAll('.code-tab').forEach(function(t) { t.classList.remove('active'); });
  btn.classList.add('active');
  document.getElementById('tab-python').style.display = tabId === 'python' ? '' : 'none';
  document.getElementById('tab-concept').style.display = tabId === 'concept' ? '' : 'none';
}
</script>
